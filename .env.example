# ============================================================
# Social Media Genie — API Keys & Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Meta / Instagram Graph API ---
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Runway (Video Generation) ---
RUNWAY_API_KEY=
RUNWAY_MODEL=gen4

# --- Stability AI (Image Generation) ---
STABILITY_API_KEY=

# --- OpenAI (DALL-E 3 + Whisper) ---
OPENAI_API_KEY=

# --- HeyGen (Avatar Videos) ---
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# --- Ayrshare (Multi-platform Scheduling) ---
AYRSHARE_API_KEY=

# --- Keywords Everywhere (SEO Research) ---
KEYWORDS_EVERYWHERE_API_KEY=

# --- WordPress.com (hemle.blog) ---
# Get token: node mcp-wordpress/get-token.js --browser --client-id ID --client-secret SECRET
WPCOM_SITE_ID=hemle.blog
WPCOM_TOKEN=

# --- Brevo (Email Newsletters) ---
# Get key: https://app.brevo.com/settings/keys/api → Generate API Key
# Or store in .brevo_token file
BREVO_API_KEY=
BREVO_SENDER_NAME=Trend Signal by Hemle
BREVO_SENDER_EMAIL=

# --- General ---
OUTPUT_DIR=./output
DEFAULT_IMAGE_PROVIDER=stability
DEFAULT_VIDEO_PROVIDER=runway
LOG_LEVEL=INFO
